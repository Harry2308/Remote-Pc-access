# Relay Server Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Admin credentials (hashed at runtime — set plain text here for first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Shared secret between relay and pc-agent
AGENT_SECRET=change-this-to-another-long-random-string

# CORS — set to your frontend URL in production
CORS_ORIGIN=http://localhost:4200
