# PC Agent Environment Variables
# Copy this file to .env and fill in your values

# Relay server WebSocket URL
RELAY_URL=wss://your-relay-server.com

# Shared secret — must match AGENT_SECRET on relay server
AGENT_SECRET=change-this-to-another-long-random-string

# Shell to use for terminal sessions
# Options: powershell, cmd
ALLOWED_SHELL=powershell

# Reconnect interval in milliseconds if relay disconnects
RECONNECT_INTERVAL=5000
