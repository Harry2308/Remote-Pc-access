# WoL Agent Environment Variables
# Copy this file to .env and fill in your values

# Port this HTTP server listens on
PORT=3003

# MAC address of the target PC (the one you want to wake)
# Format: AA:BB:CC:DD:EE:FF
TARGET_MAC=AA:BB:CC:DD:EE:FF

# Shared secret — must match AGENT_SECRET on relay server
AGENT_SECRET=change-this-to-another-long-random-string

# Broadcast address for your LAN (usually subnet.255)
BROADCAST_ADDRESS=192.168.1.255
